.program ws2812
.side_set 1

.define public T1 2
.define public T2 5
.define public T3 3

.wrap_target
bitloop:
    out x, 1       side 0 [T3 - 1] ; Side-set still 0
    jmp !x do_zero side 1 [T1 - 1] ; Branch on the bit we shifted out
do_one:
    jmp  bitloop   side 1 [T2 - 1] ; Continue driving high
do_zero:
    nop            side 0 [T2 - 1] ; Drive low
.wrap